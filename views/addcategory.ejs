<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <% if(inDB===true){%>
            <p><%=name %> is part of the database</p>
       <% } %>

       <%if(errors){ %>
        <ul>
        <%for(error of errors){%>
          <li><%=error.msg %></li>
       <% } %>
        </ul>
      <% } %>
    <form method="post">
      <label for="genre">Add Genre:</label>
      <input type="text" name="genre" id="genre" />
    </form>
    <a href="/">Go back</a>
  </body>
</html>
